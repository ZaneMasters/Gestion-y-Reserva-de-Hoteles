{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/hotels/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "rooms-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/bookings/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "admin-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://admin-service:8080/"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://booking-service:8080/"
          }
        }
      }
    }
  }
}
